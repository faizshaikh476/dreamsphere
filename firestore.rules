rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if ownsUser(userId);
    }

    match /dreams/{dreamId} {
      allow read: if resource.data.privacy == "public" || ownsUser(resource.data.user_id);
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if ownsUser(resource.data.user_id);
    }

    match /interactions/{interactionId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
